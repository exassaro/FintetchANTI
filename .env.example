# ================================================================
# Auditron — Root Environment Variables (Docker Compose)
# ================================================================
# Copy this file to .env and fill in your API keys.
# The .env file is loaded by docker-compose via env_file directives.
# DO NOT commit .env to git (it is already in .gitignore).
# ================================================================

# ── News API Keys (used by analytics service) ──────────────
NEWS_API_KEY=
NEWSDATA_API_KEY=
MEDIASTACK_API_KEY=

# ── Auth Secrets ──────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-here
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-password-here
