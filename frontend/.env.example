# ── Frontend Environment Variables ──────────────────────────
# Used by Vite's dev server proxy (vite.config.js).
# In Docker/production, Nginx handles routing — these are NOT used.

VITE_AUTH_URL=http://localhost:8004
VITE_CLASSIFICATION_URL=http://localhost:8001
VITE_ANOMALY_URL=http://localhost:8002
VITE_ANALYTICS_URL=http://localhost:8003
VITE_RETRAINING_URL=http://localhost:8005
