# ── .dockerignore for anomaly_service ───────────────────────────────────────
# Keeps build context lean by excluding anything not needed in the image.

# Git & CI
.git
.gitignore
.github
.dockerignore

# Python byte-code & caches
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
.cache
.mypy_cache
.ruff_cache
.pytest_cache

# Virtual environments
.venv
venv
env
ENV

# Editor / IDE configs
.vscode
.idea
*.code-workspace

# Tests (not needed at runtime)
tests/
**/test_*.py
**/*_test.py

# ML model files – models are downloaded at runtime, NOT baked into the image
*.bin
*.pt
*.pth
*.onnx
*.safetensors
models/
mlruns/
mlartifacts/

# Data files
*.csv
*.parquet
*.json
*.jsonl
*.pkl
*.pickle
data/

# Logs & temp files
*.log
logs/
tmp/
temp/

# OS noise
.DS_Store
Thumbs.db

# Documentation (not needed in the image)
*.md
docs/

# Node (if any stray files exist)
node_modules/
